# .env.example
# Copy this file to .env.local and fill in your values

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=your_db_password
DB_NAME=salon_dev
DB_SSL=false
DB_CA_PATH=

REDIS_URL=rediss://default:your_upstash_password@your-upstash-host.upstash.io:6379

JWT_ACCESS_SECRET=your_access_secret
JWT_REFRESH_SECRET=your_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

APP_BASE_URL=http://your-server-ip:5173
FRONTEND_URL=http://your-server-ip:5173
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://your-server-ip:5173,http://your-server-ip:3000
PORT=3000

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="Salon App <your_email@gmail.com>"
OTP_EXP_MINUTES=5

EXOTEL_ACCOUNT_SID=your_account_sid
EXOTEL_SMS_APP_ID=your_app_id
EXOTEL_SMS_APP_SECRET=your_app_secret

GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://your-server-ip:3000/api/v1/auth/google/callback
GOOGLE_ONE_TAP_CLIENT_ID=your_google_client_id

RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

WA_API_VERSION=v19.0
WA_BASE_URL=https://graph.facebook.com
WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token
