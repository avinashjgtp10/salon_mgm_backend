{
  "name": "salon_mgm_backend",
  "version": "1.0.0",
  "description": "AI-Powered Salon Management Platform - Backend",
  "main": "src/server.ts",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:prod": "NODE_ENV=production node dist/server.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "migrate:create": "node-pg-migrate create",
    "migrate:up": "node-pg-migrate up",
    "migrate:down": "node-pg-migrate down",
    "migrate:up:dev": "NODE_ENV=development node-pg-migrate up",
    "migrate:up:prod": "NODE_ENV=production node-pg-migrate up",
    "seed": "ts-node src/database/seeds/run-seeds.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/avinashjgtp10/salon_mgm_backend.git"
  },
  "keywords": [
    "salon",
    "management",
    "api",
    "typescript"
  ],
  "author": "Avinash",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/avinashjgtp10/salon_mgm_backend/issues"
  },
  "homepage": "https://github.com/avinashjgtp10/salon_mgm_backend#readme",
  "dependencies": {
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "aws-sdk": "^2.1693.0",
    "axios": "^1.13.5",
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "bull": "^4.16.5",
    "bullmq": "^5.71.0",
    "compression": "^1.8.1",
    "cors": "^2.8.6",
    "csv-parser": "^3.2.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "express-validator": "^7.3.1",
    "fast-csv": "^5.0.5",
    "helmet": "^8.1.0",
    "ioredis": "^5.9.3",
    "joi": "^18.0.2",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "lodash": "^4.17.23",
    "morgan": "^1.10.1",
    "multer": "^2.0.2",
    "node-pg-migrate": "^8.0.4",
    "nodemailer": "^8.0.1",
    "pdfkit": "^0.17.2",
    "pg": "^8.20.0",
    "rate-limit-redis": "^4.3.1",
    "rate-limiter-flexible": "^9.1.1",
    "razorpay": "^2.9.6",
    "sharp": "^0.34.5",
    "swagger-ui-express": "^5.0.1",
    "twilio": "^5.12.1",
    "uuid": "^9.0.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "yamljs": "^0.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
